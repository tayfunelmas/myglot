# Required — path to service-account JSON (see docs/GOOGLE_CLOUD_SETUP.md)
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp.json

# Optional — where SQLite DB and audio files live (default: ./data)
MYGLOT_DATA_DIR=./data

# Optional — bind address (default: 127.0.0.1)
MYGLOT_HOST=127.0.0.1
MYGLOT_PORT=8000

# Initial defaults used ONLY on first run to seed settings.
# After first run, change via Settings UI.
MYGLOT_DEFAULT_SOURCE_LANG=en-US
MYGLOT_DEFAULT_TARGET_LANG=de-DE
MYGLOT_DEFAULT_TTS_VOICE=

# Provider selection (each capability is independent)
# Translate providers: google | fake | ollama
MYGLOT_TRANSLATE_PROVIDER=google
MYGLOT_TTS_PROVIDER=google
MYGLOT_STT_PROVIDER=google

# Vendor credentials — only set the ones your selected providers need
# GOOGLE_APPLICATION_CREDENTIALS is set above for Google providers.
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

# Ollama settings (only needed when MYGLOT_TRANSLATE_PROVIDER=ollama)
# Requires `ollama serve` running locally with the model pulled.
MYGLOT_OLLAMA_BASE_URL=http://localhost:11434
MYGLOT_OLLAMA_MODEL=translategemma:latest

# Limits
MYGLOT_MAX_SOURCE_CHARS=2000
MYGLOT_MAX_AUDIO_UPLOAD_MB=10
